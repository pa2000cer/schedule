{
  "name": "personal-calendar",
  "version": "0.1.0",
  "private": true,
  "description": "Single-user personal calendar app: browser day-view front end + a Calendar MCP server (Google Calendar + Claude).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch server/src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:firestore": "tsx scripts/firestore-smoke.ts",
    "smoke:sync": "tsx scripts/sync-smoke.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google-cloud/firestore": "^8.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
