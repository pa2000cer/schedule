# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit real secrets.
# Cloud Run sets PORT automatically; default here is for local runs.
PORT=8080

# Single-user allowlist — only this Google account may sign in (see Authentication).
ALLOWED_EMAIL=pacewelch@gmail.com

# --- Google Calendar OAuth (project tv-api-gc) ---
# OAuth 2.0 Web client. Client ID is not secret; the client secret is stored in
# Google Secret Manager as `google-oauth-client-secret` and injected into Cloud Run
# at deploy time (--set-secrets). For local dev, put the real secret in .env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URIs registered on the OAuth client:
#   local:     http://localhost:8080/auth/google/callback
#   Cloud Run: https://personal-calendar-v6fqta4rbq-uc.a.run.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# --- Session signing secret (T4 auth) ---
# HS256 key used to sign the session cookie (JWT). Generate a strong random
# value, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Local dev: set it here. Cloud Run (T15): inject from Secret Manager, do not commit.
SESSION_SECRET=

# --- Claude / Anthropic (used by the MCP routing layer, later task) ---
# The user enters their own key in the front end at runtime; not required to boot the server.
ANTHROPIC_API_KEY=

# --- MCP server bearer token (T6) ---
# Required to boot the server (see server/src/mcp/auth.ts) — the /mcp endpoint
# refuses to serve without it. This is NOT the browser session cookie; MCP
# clients (Claude Desktop/Code, T17) send it as `Authorization: Bearer <token>`.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=
